            "name": "search",
            "in": "query",
            "description": "Search users by name or email.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "is_global_admin",
            "in": "query",
            "description": "Filter users by global admin flag.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "tenant_id",
            "in": "query",
            "description": "Filter users linked to this tenant ID.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "active",
            "in": "query",
            "description": "Filter tenant pivot active status when tenant_id is provided.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "sort_by",
            "in": "query",
            "description": "Safe sort field: id or created_at.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Items per page.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "const": "Users fetched successfully."
                    },
                    "status": {
                      "type": "boolean"
                    },
                    "code": {
                      "type": "integer",
                      "const": 200
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "anyOf": [
                            {
                              "type": "string"
                            },
                            {
                              "type": "array",
                              "items": {
                                "type": "string"
                              },
                              "minItems": 0,
                              "maxItems": 0,
                              "additionalItems": false
                            }
                          ]
                        },
                        "meta": {
                          "type": "string"
                        },
                        "links": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "data",
                        "meta",
                        "links"
                      ]
                    }
                  },
                  "required": [
                    "message",
                    "status",
                    "code",
                    "data"
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/AuthenticationException"
          }
        }
      },
      "post": {
        "operationId": "createAdminUser",
        "tags": [
          "Admin Users"
        ],
        "requestBody": {
          "required": true,
