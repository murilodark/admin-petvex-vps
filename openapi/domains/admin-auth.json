{
  "openapi": "3.1.0",
  "info": {
    "title": "PetVex Admin - Admin Auth",
    "version": "0.0.1",
    "description": "Filtered OpenAPI specification for Admin Auth."
  },
  "servers": [
    {
      "url": "http://localhost/api"
    }
  ],
  "paths": {
    "/v1/admin/auth/login": {
      "post": {
        "operationId": "loginAdminAuthLogin",
        "tags": [
          "Admin Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdminLoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "const": "Admin login successfully."
                    },
                    "status": {
                      "type": "boolean"
                    },
                    "code": {
                      "type": "integer",
                      "const": 200
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "token": {
                          "type": "string"
                        },
                        "admin": {
                          "type": "array",
                          "items": []
                        }
                      },
                      "required": [
                        "token",
                        "admin"
                      ]
                    }
                  },
                  "required": [
                    "message",
                    "status",
                    "code",
                    "data"
                  ]
                }
              }
            }
          },
          "422": {
            "$ref": "#/components/responses/ValidationException"
          }
        }
      }
    },
    "/v1/admin/auth/logout": {
      "post": {
        "operationId": "logoutAdminAuthLogout",
        "tags": [
          "Admin Auth"
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "const": "Admin logout successfully."
                    },
                    "status": {
                      "type": "boolean"
                    },
                    "code": {
                      "type": "integer",
                      "const": 200
                    },
                    "data": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "message",
                    "status",
                    "code",
                    "data"
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/AuthenticationException"
          }
        }
      }
    },
    "/v1/admin/auth/me": {
      "get": {
        "operationId": "meAdminAuthMe",
        "tags": [
          "Admin Auth"
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "const": "Authenticated admin fetched successfully."
                    },
                    "status": {
                      "type": "boolean"
                    },
                    "code": {
                      "type": "integer",
                      "const": 200
                    },
                    "data": {
                      "type": [
                        "array",
                        "null"
                      ],
                      "items": []
                    }
                  },
                  "required": [
                    "message",
                    "status",
                    "code",
                    "data"
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/AuthenticationException"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AdminLoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "title": "AdminLoginRequest"
      }
    },
    "responses": {
      "ValidationException": {
        "description": "Validation error",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string",
                  "description": "Errors overview."
                },
                "errors": {
                  "type": "object",
                  "description": "A detailed description of each field that failed validation.",
                  "additionalProperties": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "required": [
                "message",
                "errors"
              ]
            }
          }
        }
      },
      "AuthenticationException": {
        "description": "Unauthenticated",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string",
                  "description": "Error overview."
                }
              },
              "required": [
                "message"
              ]
            }
          }
        }
      }
    }
  }
}
